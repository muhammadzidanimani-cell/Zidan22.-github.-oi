<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Portofolio [Muhammad Zidan Imani]</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }
    body {
      background: #0f0f0f;
      color: white;
      line-height: 1.6;
    }
    header {
      text-align: center;
      padding: 80px 20px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    header h1 {
      font-size: 48px;
      margin-bottom: 10px;
    }
    header p {
      font-size: 18px;
      opacity: 0.9;
    }
    section {
      padding: 60px 20px;
      max-width: 1000px;
      margin: auto;
    }
    h2 {
      text-align: center;
      margin-bottom: 30px;
      font-size: 32px;
    }
    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }
    .gallery img {
      width: 100%;
      border-radius: 12px;
      transition: 0.3s;
    }
    .gallery img:hover {
      transform: scale(1.05);
    }
    .skills {
      display: flex;
      justify-content: center;
      gap: 30px;
      flex-wrap: wrap;
    }
    .skills span {
      background: #1e1e1e;
      padding: 10px 20px;
      border-radius: 20px;
      border: 1px solid #333;
    }
    footer {
      text-align: center;
      padding: 30px;
      background: #1e1e1e;
    }
    a {
      color: #667eea;
      text-decoration: none;
    }
  </style>
</head>
<body>

  <header>
    <h1>Muhammad Zidan Imani</h1>
    <p>Siswa X DKV 1 SMK 8 | Proyek Coding</p>
  </header>

  <section>
    <h2>Karya Terbaik</h2>
    <div class="gallery">
      <img src=https://i.imgur.com/x0nz5fL.jpg alt="Karya 1">
      <img src=https://i.imgur.com/6257zE9.jpg alt="Karya 2">
      <img src=https://i.imgur.com/RWYP7tj.png alt="Karya 3">
    </div>
  </section>

  <section>
    <h2>Skill</h2>
    <div class="skills">
      <span>Capcut</span>
      <span>Illustrator</span>
      <span>Canva</span>
    </div>
  </section>

  <section>
    <h2>Hubungi Saya</h2>
    <footer>
      <p>IG: @danziey.zdn| Email: danwesmaem@gmail.com</p>
    </footer>
  </section>

</body>
</html>
